# Dependencies
node_modules

# Build outputs
dist
dist-ssr

# Local env files
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Android build artifacts
app-debug.apk
app-release.apk
*.apk
*.aab

# Android Gradle cache (local build state, not needed in repo)
android/.gradle/
android/app/build/
android/build/
